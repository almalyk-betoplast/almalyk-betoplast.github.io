---
import { site } from '../data/site';
import { getLang, t, localizePath, navItems } from '../i18n/utils';

const lang = getLang(Astro.currentLocale);
const tr = t(lang);
const year = 2026;
---

<footer class="ftr">
  <div class="container ftr__grid">
    <div class="ftr__brand">
      <a href={localizePath('/', lang)} class="brand">
        <span class="brand__mark" aria-hidden="true">Cu</span>
        <span class="brand__text"><strong>Almalyk MMC</strong> – Betoplast</span>
      </a>
      <p class="ftr__desc">{tr.footer.desc}</p>
    </div>

    <nav class="ftr__col" aria-label="Footer">
      <h4>{tr.footer.navigate}</h4>
      {navItems.map((item) => <a href={localizePath(item.href, lang)}>{tr.nav[item.key]}</a>)}
    </nav>

    <div class="ftr__col">
      <h4>{tr.footer.office}</h4>
      <address>
        {tr.address.line1}<br />
        {tr.address.line2}<br />
        {tr.address.country}
      </address>
      <p class="ftr__legal">{tr.legalEntity}<br />{tr.footer.tin} {site.tin}</p>
    </div>
  </div>

  <div class="container ftr__bottom">
    <span>© {year} {tr.legalEntity}. {tr.footer.rights}</span>
    <span class="ftr__note">{tr.footer.note}</span>
  </div>
</footer>

<style>
  .ftr { background: var(--ink); color: #9fb0c2; padding-top: clamp(3rem, 6vw, 4.5rem); }
  .ftr__grid {
    display: grid; grid-template-columns: 1.6fr 1fr 1.2fr; gap: 2.5rem;
    padding-bottom: 3rem; border-bottom: 1px solid rgba(255,255,255,.1);
  }
  .ftr .brand { display: flex; align-items: center; gap: .7rem; }
  .ftr .brand__mark {
    width: 38px; height: 38px; border-radius: 6px;
    display: grid; place-items: center;
    background: var(--steel-500); color: #fff;
    font-weight: 800; font-size: 1.05rem; letter-spacing: -.03em;
    flex: none;
  }
  .ftr .brand__text { color: #fff; font-size: 1.02rem; letter-spacing: -.01em; }
  .ftr__desc { margin-top: 1.1rem; max-width: 36ch; font-size: .92rem; line-height: 1.6; color: #8295a8; }
  .ftr__col h4 { color: #fff; font-size: .8rem; letter-spacing: .12em; text-transform: uppercase; margin-bottom: 1.1rem; }
  .ftr__col a { display: block; padding: .3rem 0; font-size: .92rem; color: #9fb0c2; transition: color .18s var(--ease); }
  .ftr__col a:hover { color: #fff; }
  .ftr__col address { font-style: normal; font-size: .92rem; line-height: 1.7; color: #9fb0c2; }
  .ftr__legal { margin-top: 1rem; font-size: .82rem; color: #6f8094; }
  .ftr__bottom {
    display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
    padding-block: 1.6rem; font-size: .82rem; color: #6f8094;
  }
  @media (max-width: 820px) { .ftr__grid { grid-template-columns: 1fr; gap: 2rem; } }
</style>
