---
import { site } from '../data/site';
import { getLang, t, localizePath, navItems, locales } from '../i18n/utils';
import { languages } from '../i18n/ui';

const lang = getLang(Astro.currentLocale);
const tr = t(lang);
const currentPath = Astro.url.pathname;
const base = currentPath.replace(/^\/(ru|uz)(?=\/|$)/, '') || '/';
const isActive = (href: string) => (href === '/' ? base === '/' : base.startsWith(href));

const homeHref = localizePath('/', lang);
const contactHref = localizePath('/contact', lang);
---

<header class="hdr" id="site-header">
  <div class="container hdr__inner">
    <a href={homeHref} class="brand" aria-label={site.name}>
      <span class="brand__mark" aria-hidden="true">Cu</span>
      <span class="brand__text">
        <span class="brand__top">Almalyk MMC</span>
        <span class="brand__bottom">Betoplast</span>
      </span>
    </a>

    <nav class="nav" aria-label="Primary">
      {navItems.map((item) => (
        <a href={localizePath(item.href, lang)} class:list={['nav__link', { 'is-active': isActive(item.href) }]}>
          {tr.nav[item.key]}
        </a>
      ))}
    </nav>

    <details class="lang-dd" id="lang-dd">
      <summary class="lang-dd__btn" aria-label="Language" title="Language">
        <span>{languages[lang].short}</span>
        <svg class="lang-dd__chev" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 6l4 4 4-4" /></svg>
      </summary>
      <ul class="lang-dd__menu" role="menu">
        {locales.map((loc) => (
          <li role="none">
            <a
              role="menuitem"
              href={localizePath(currentPath, loc)}
              hreflang={loc}
              class:list={['lang-dd__opt', { 'is-active': loc === lang }]}
              aria-current={loc === lang ? 'true' : undefined}
            >
              <span class="lang-dd__code">{languages[loc].short}</span>
              <span class="lang-dd__label">{languages[loc].label}</span>
            </a>
          </li>
        ))}
      </ul>
    </details>

    <a href={contactHref} class="btn btn--primary hdr__cta">{tr.common.getInTouch}</a>

    <button class="hdr__burger" aria-label="Menu" aria-expanded="false" id="burger">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-nav" id="mobile-nav" hidden>
    {navItems.map((item) => (
      <a href={localizePath(item.href, lang)} class:list={['mobile-nav__link', { 'is-active': isActive(item.href) }]}>
        {tr.nav[item.key]}
      </a>
    ))}
    <div class="mobile-langs">
      {locales.map((loc) => (
        <a href={localizePath(currentPath, loc)} class:list={['mlang', { 'is-active': loc === lang }]} hreflang={loc}>
          {languages[loc].short}
        </a>
      ))}
    </div>
    <a href={contactHref} class="btn btn--primary" style="margin: 1rem 1.5rem;">{tr.common.getInTouch}</a>
  </div>
</header>

<style>
  .hdr {
    position: sticky; top: 0; z-index: 50;
    background: rgba(255, 255, 255, .88);
    backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--line);
    transition: box-shadow .25s var(--ease);
  }
  .hdr.scrolled { box-shadow: var(--shadow-sm); }
  .hdr__inner { display: flex; align-items: center; gap: 1.1rem; height: 74px; }

  .brand { display: flex; align-items: center; gap: .7rem; margin-right: auto; }
  .brand__mark {
    width: 44px; height: 44px; border-radius: 8px; flex: none;
    display: grid; place-items: center;
    background: var(--steel); color: #fff;
    font-family: var(--font-display);
    font-weight: 700; font-size: 1.3rem; letter-spacing: -.02em;
  }
  .brand__text { display: flex; flex-direction: column; line-height: 1; white-space: nowrap; }
  .brand__top {
    font-family: var(--font-display); font-weight: 700; font-size: 1.06rem;
    letter-spacing: -.01em; color: var(--ink);
  }
  .brand__bottom {
    font-family: var(--font-display); font-weight: 600; text-transform: uppercase;
    font-size: .62rem; letter-spacing: .315em; color: var(--steel-500);
    margin-top: .26rem; margin-right: -.315em;
  }

  .nav { display: flex; gap: .15rem; }
  .nav__link {
    padding: .5rem .65rem; border-radius: var(--radius);
    font-size: .9rem; font-weight: 500; color: var(--muted);
    transition: color .18s var(--ease), background .18s var(--ease);
    white-space: nowrap;
  }
  .nav__link:hover { color: var(--ink); background: var(--bg-soft); }
  .nav__link.is-active { color: var(--steel); font-weight: 600; }

  /* Language dropdown */
  .lang-dd { position: relative; flex: none; }
  .lang-dd__btn {
    list-style: none; cursor: pointer;
    display: inline-flex; align-items: center; gap: .35rem;
    padding: .45rem .55rem; border-radius: var(--radius);
    border: 1px solid var(--line-2); background: transparent;
    font-size: .82rem; font-weight: 600; letter-spacing: .03em; color: var(--ink-2);
    transition: border-color .18s var(--ease), background .18s var(--ease);
  }
  .lang-dd__btn::-webkit-details-marker { display: none; }
  .lang-dd__btn:hover { border-color: var(--steel-300); background: var(--bg-soft); }
  .lang-dd__chev { width: 12px; height: 12px; color: var(--muted); transition: transform .2s var(--ease); }
  .lang-dd[open] .lang-dd__chev { transform: rotate(180deg); }
  .lang-dd[open] .lang-dd__btn { border-color: var(--steel-500); background: var(--bg-soft); }
  .lang-dd__menu {
    position: absolute; right: 0; top: calc(100% + 8px); z-index: 60;
    min-width: 158px; margin: 0; padding: .35rem; list-style: none;
    background: #fff; border: 1px solid var(--line); border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
  }
  .lang-dd__opt {
    display: flex; align-items: center; gap: .65rem;
    padding: .5rem .6rem; border-radius: var(--radius);
    font-size: .92rem; color: var(--ink); transition: background .15s var(--ease);
  }
  .lang-dd__opt:hover { background: var(--bg-soft); }
  .lang-dd__opt.is-active { color: var(--copper-600); font-weight: 600; }
  .lang-dd__code { font-size: .72rem; font-weight: 700; letter-spacing: .04em; color: var(--muted); width: 2ch; }
  .lang-dd__opt.is-active .lang-dd__code { color: var(--copper-600); }

  .hdr__cta { padding: .6rem 1.05rem; font-size: .88rem; white-space: nowrap; flex: none; }

  .hdr__burger { display: none; flex-direction: column; gap: 5px; background: none; border: 0; padding: 8px; }
  .hdr__burger span { width: 24px; height: 2px; background: var(--ink); transition: transform .25s var(--ease), opacity .2s; }
  .hdr__burger[aria-expanded='true'] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hdr__burger[aria-expanded='true'] span:nth-child(2) { opacity: 0; }
  .hdr__burger[aria-expanded='true'] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-nav { border-bottom: 1px solid var(--line); background: #fff; padding-block: .5rem; }
  .mobile-nav__link { display: block; padding: .85rem 1.5rem; font-weight: 500; color: var(--ink); border-bottom: 1px solid var(--line); }
  .mobile-nav__link.is-active { color: var(--steel); }
  .mobile-langs { display: flex; gap: .4rem; padding: 1rem 1.5rem .25rem; }
  .mlang {
    font-size: .8rem; font-weight: 600; letter-spacing: .03em; color: var(--muted);
    padding: .4rem .7rem; border-radius: var(--radius); border: 1px solid var(--line);
  }
  .mlang.is-active { color: var(--copper-600); border-color: var(--copper-300); }

  @media (max-width: 1100px) {
    .nav, .hdr__cta, .lang-dd { display: none; }
    .hdr__burger { display: flex; }
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const onScroll = () => header?.classList.toggle('scrolled', window.scrollY > 8);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const burger = document.getElementById('burger');
  const menu = document.getElementById('mobile-nav');
  burger?.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!open));
    if (menu) menu.hidden = open;
  });

  // Language dropdown: close on outside click or Escape.
  const dd = document.getElementById('lang-dd') as HTMLDetailsElement | null;
  if (dd) {
    document.addEventListener('click', (e) => {
      if (dd.open && !dd.contains(e.target as Node)) dd.open = false;
    });
    dd.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Escape') dd.open = false;
    });
  }
</script>
