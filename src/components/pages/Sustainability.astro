---
import Base from '../../layouts/Base.astro';
import CtaBand from '../CtaBand.astro';
import { getLang, t } from '../../i18n/utils';

const lang = getLang(Astro.currentLocale);
const tr = t(lang);
---

<Base title={tr.nav.sustainability} description={tr.sustainability.heroLead}>
  <section class="page-hero">
    <div class="page-hero__bg" aria-hidden="true"></div>
    <div class="container">
      <p class="eyebrow">{tr.sustainability.heroEyebrow}</p>
      <h1>{tr.sustainability.heroH1}</h1>
      <p class="lead mt-2">{tr.sustainability.heroLead}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid cols-2">
        {tr.sustainability.commitments.map((c) => (
          <div class="commit reveal">
            <h3>{c.title}</h3>
            <p>{c.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand heading={tr.sustainability.ctaHeading} text={tr.sustainability.ctaText} />
</Base>

<style>
  .page-hero { position: relative; color: #fff; isolation: isolate; padding-block: clamp(4rem, 10vw, 7rem); }
  .page-hero__bg {
    position: absolute; inset: 0; z-index: -1;
    background:
      linear-gradient(110deg, rgba(13,19,27,.92) 35%, rgba(28,61,94,.7)),
      url('/images/sustainability.jpg') center / cover no-repeat;
  }
  .page-hero h1 { color: #fff; }
  .page-hero .lead { color: #cdd8e2; max-width: 56ch; }
  .page-hero .eyebrow { color: var(--steel-300); }
  .page-hero .eyebrow::before { background: var(--copper-300); }

  .commit { padding: 1.9rem 0; border-top: 2px solid var(--ink); }
  .commit h3 { margin-bottom: .7rem; }
  .commit p { color: var(--muted); font-size: .98rem; }
</style>
