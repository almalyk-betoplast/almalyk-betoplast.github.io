---
import Base from '../../layouts/Base.astro';
import CtaBand from '../CtaBand.astro';
import ProductCard from '../ProductCard.astro';
import { products } from '../../data/products';
import { getLang, t, localizePath } from '../../i18n/utils';

const lang = getLang(Astro.currentLocale);
const tr = t(lang);

const highlights = products.filter((p) =>
  ['of-ofe-copper-rod', 'ed-copper-foil', 'wire-bonding', 'electronics-grade-hub'].includes(p.slug)
);
const statIcons = [
  '<path d="M12 2.5 20.5 7.25v9.5L12 21.5 3.5 16.75v-9.5z" /><circle cx="12" cy="12" r="3" />',
  '<path d="M12 3 21 8l-9 5-9-5z" /><path d="M3 12l9 5 9-5" /><path d="M3 16l9 5 9-5" />',
  '<circle cx="12" cy="12" r="8.5" /><path d="M7 12h10" /><path d="M9.2 9.8 7 12l2.2 2.2M14.8 9.8 17 12l-2.2 2.2" />',
  '<path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z" /><path d="M14 3v5h5" /><path d="M8.5 13.5l2 2 4-4" />',
];
---

<Base>
  <section class="hero">
    <div class="hero__bg" aria-hidden="true"><div class="hero__img"></div></div>
    <div class="container hero__inner">
      <p class="eyebrow">{tr.home.heroEyebrow}</p>
      <h1 set:html={tr.home.heroH1} />
      <p class="lead">{tr.home.heroLead}</p>
      <div class="hero__actions">
        <a href={localizePath('/products', lang)} class="btn btn--light">{tr.common.exploreProducts} <span class="arrow">→</span></a>
        <a href={localizePath('/contact', lang)} class="btn btn--on-dark">{tr.common.getInTouch}</a>
      </div>
    </div>
  </section>

  <section class="stats">
    <div class="container stats__grid">
      {tr.home.stats.map((s, i) => (
        <div class="stat">
          <span class="stat__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={statIcons[i]} />
          </span>
          <strong>{s.v}</strong><span>{s.l}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="container intro">
      <div class="section-head reveal">
        <p class="eyebrow">{tr.home.introEyebrow}</p>
        <h2>{tr.home.introH2}</h2>
        <p class="lead mt-2">{tr.home.introLead}</p>
      </div>

      <div class="grid cols-2">
        {tr.home.capabilities.map((c) => (
          <div class="cap reveal">
            <h3>{c.title}</h3>
            <p>{c.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <div class="section-head reveal">
        <p class="eyebrow">{tr.home.productsEyebrow}</p>
        <h2>{tr.home.productsH2}</h2>
      </div>
      <div class="grid cols-4">
        {highlights.map((p) => <ProductCard product={p} />)}
      </div>
      <div class="mt-4 reveal">
        <a href={localizePath('/products', lang)} class="btn btn--ghost">{tr.common.viewRange} <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  <CtaBand />
</Base>

<style>
  .hero { position: relative; color: #fff; isolation: isolate; }
  .hero__bg { position: absolute; inset: 0; z-index: -1; overflow: hidden; }
  .hero__img {
    position: absolute; inset: 0;
    background: url('/images/hero.jpg') center / cover no-repeat;
    transform: scale(1.04);
    animation: kenburns 32s ease-in-out infinite alternate;
    will-change: transform;
  }
  .hero__bg::after {
    content: ""; position: absolute; inset: 0;
    background: linear-gradient(105deg, rgba(13,19,27,.92) 35%, rgba(18,25,34,.62) 100%);
  }
  @keyframes kenburns { from { transform: scale(1.04); } to { transform: scale(1.14); } }

  .hero__inner { padding-block: clamp(5rem, 13vw, 9.5rem); max-width: 820px; }
  .hero h1 { color: #fff; margin-block: .4rem 1.5rem; }
  .hero .lead { color: #cdd8e2; max-width: 60ch; }
  .hero__actions { display: flex; gap: .9rem; margin-top: 2.2rem; flex-wrap: wrap; }
  .hero .eyebrow { color: var(--steel-300); }
  .hero .eyebrow::before { background: var(--copper-300); }

  /* Hero text entrance (on load, staggered) */
  .hero .eyebrow { animation: heroIn .8s var(--ease) both; }
  .hero h1       { animation: heroIn .8s var(--ease) .12s both; }
  .hero .lead    { animation: heroIn .8s var(--ease) .24s both; }
  .hero__actions { animation: heroIn .8s var(--ease) .36s both; }
  @keyframes heroIn { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: none; } }

  @media (prefers-reduced-motion: reduce) {
    .hero__img { animation: none; transform: none; }
    .hero .eyebrow, .hero h1, .hero .lead, .hero__actions { animation: none; }
  }

  .stats { border-bottom: 1px solid var(--line); }
  .stats__grid { display: grid; grid-template-columns: repeat(4, 1fr); }
  .stat { padding: 2.2rem 1.5rem; text-align: center; border-right: 1px solid var(--line); }
  .stat:last-child { border-right: 0; }
  .stat__icon { display: grid; place-items: center; margin-bottom: 1.1rem; color: var(--steel-500); }
  .stat__icon svg { width: 52px; height: 52px; stroke-width: 1.25; }
  .stat strong { display: block; font-family: var(--font-heading); font-size: 1.75rem; font-weight: 700; color: var(--steel); letter-spacing: -.02em; }
  .stat span { font-size: .85rem; color: var(--muted); }
  @media (max-width: 720px) {
    .stats__grid { grid-template-columns: repeat(2, 1fr); }
    .stat:nth-child(2) { border-right: 0; }
    .stat:nth-child(1), .stat:nth-child(2) { border-bottom: 1px solid var(--line); }
  }

  .cap { padding: 1.7rem 0; border-top: 2px solid var(--ink); }
  .cap h3 { margin-bottom: .6rem; }
  .cap p { color: var(--muted); font-size: .96rem; }
</style>

<script>
  // Count-up for numeric stat values, when the strip scrolls into view.
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const nums = document.querySelectorAll<HTMLElement>('.stats .stat strong');
  if (!reduce && nums.length) {
    const animate = (el: HTMLElement) => {
      const target = el.textContent || '';
      if (!/\d/.test(target)) return;
      const parts = target.split(/(\d+)/);
      const dur = 1100;
      const start = performance.now();
      const step = (now: number) => {
        const p = Math.min(1, (now - start) / dur);
        const e = 1 - Math.pow(1 - p, 3);
        el.textContent = parts.map((s) => (/^\d+$/.test(s) ? String(Math.round(Number(s) * e)) : s)).join('');
        if (p < 1) requestAnimationFrame(step);
        else el.textContent = target;
      };
      requestAnimationFrame(step);
    };
    const io = new IntersectionObserver(
      (entries) => entries.forEach((en) => { if (en.isIntersecting) { animate(en.target as HTMLElement); io.unobserve(en.target); } }),
      { threshold: 0.5 }
    );
    nums.forEach((n) => io.observe(n));
  }
</script>
